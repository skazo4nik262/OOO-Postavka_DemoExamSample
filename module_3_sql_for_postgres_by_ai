SELECT 
    o.id AS order_id,
    o.product_id,
    p.title AS product_name,
    o.count AS quantity,
    SUM(pl.price * s.material_count) AS unit_material_cost,
    SUM(pl.price * s.material_count * o.count) AS total_order_cost
FROM orders o
JOIN products p ON o.product_id = p.id
JOIN specifications s ON s.product_id = p.id
JOIN products m ON s.material_id = m.id
JOIN price_list pl ON pl.product_id = m.id
GROUP BY o.id, o.product_id, p.title, o.count
