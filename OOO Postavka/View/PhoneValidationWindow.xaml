<Window x:Class="OOO_Postavka.View.PhoneValidationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OOO_Postavka.View"
        mc:Ignorable="d"
        Title="Валидация номера телефона" Height="200" Width="450" MinHeight="200" MinWidth="450" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="0.8*"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Button Content="Получить данные" VerticalAlignment="Center" HorizontalAlignment="Center" Width="170px" Click="GetDataClick"/>
        <Label x:Name="phoneLabel" Grid.Column="1" VerticalAlignment="Center"/>
        <Button Content="Отправить результаты теста" VerticalAlignment="Center" HorizontalAlignment="Center" Width="170px" Click="PushTestResultClick" Grid.Row="1"/>
        <Label x:Name="resultLabel" Grid.Column="1" Grid.Row="1" VerticalAlignment="Center"/>
    </Grid>
</Window>
