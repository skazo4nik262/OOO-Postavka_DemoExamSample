<Window x:Class="OOO_Postavka.View.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OOO_Postavka.View"
        mc:Ignorable="d"
        Title="Администратор" Height="450" Width="800" MinHeight="450" MinWidth="600" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="usersGrid" IsReadOnly="True" SelectionMode="Single" ItemsSource="{Binding UsersList}" AutoGenerateColumns="False" SelectedItem="{Binding SelectedUser}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Width="50" Binding="{Binding Id}"/>
                <DataGridTextColumn Header="Логин" Width="*" Binding="{Binding Login}"/>
                <DataGridTextColumn Header="Роль" Width="*" Binding="{Binding Role.Title}"/>
                <DataGridCheckBoxColumn Header="Заблокирован" Width="100" Binding="{Binding IsBlocked}"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="1">
            <Button Content="Добавить" Click="AddUserClick" Width="100" Margin="5"/>
            <Button Content="Редактировать" Click="EditUserClick" Width="100" Margin="5"/>
            <Button Content="Разблокировать" Click="UnblockUserClick" Width="120" Margin="5"/>
            <Button Content="Выход" Click="ExitClick" Width="100" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
