<Window x:Class="OOO_Postavka.View.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OOO_Postavka.View"
        mc:Ignorable="d"
        Title="Регистрация" Height="450" Width="350" MinWidth="350" MinHeight="450" WindowStartupLocation="CenterScreen">
    <StackPanel>
        <Label Content="Регистрация" HorizontalAlignment="Center"/>
        <Label Content="Логин"/>
        <TextBox Text="{Binding Login}"/>
        <Label Content="Пароль"/>
        <TextBox Text="{Binding Password}"/>
        <Label Content="Подтвердите пароль"/>
        <TextBox Text="{Binding PasswordControl}"/>
        <Button Click="RegistrationClick" Content="Зарегистрироваться"/>
        <Button Click="OpenLoginWindowClick" Content="Уже есть аккаунт"/>
    </StackPanel>
</Window>
