<Window x:Class="OOO_Postavka.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OOO_Postavka"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="350" MinWidth="350" MinHeight="450" WindowStartupLocation="CenterScreen">
    <StackPanel>
        <Label Content="Авторизация" HorizontalAlignment="Center"/>
        <Label Content="Логин:"/>
        <TextBox Text="{Binding Login}"/>
        <Label Content="Пароль:"/>
        <TextBox Text="{Binding Password}"/>
        <UniformGrid Rows="2" Columns="2" x:Name="targetGrid" HorizontalAlignment="Center" Margin="0 5">
            <Button x:Name="btn1" BorderThickness="1" Padding="0" Width="60" Height="60" Click="GetNewImageClick">
                <Image Stretch="Uniform"/>
            </Button>
            <Button x:Name="btn2" BorderThickness="1" Padding="0" Width="60" Height="60" Click="GetNewImageClick">
                <Image Stretch="Uniform"/>
            </Button>
            <Button x:Name="btn3" BorderThickness="1" Padding="0" Width="60" Height="60" Click="GetNewImageClick">
                <Image Stretch="Uniform"/>
            </Button>
            <Button x:Name="btn4" BorderThickness="1" Padding="0" Width="60" Height="60" Click="GetNewImageClick">
                <Image Stretch="Uniform"/>
            </Button>
        </UniformGrid>
        <StackPanel Orientation="Horizontal" x:Name="sourcePanel" Margin="0 5" HorizontalAlignment="Center">
            <Button Width="60" Height="60" Click="PickImageClick" BorderThickness="1" Padding="0" Tag="1">
                <Image Source="/Images/1.png" Stretch="Uniform"/>
            </Button>
            <Button Width="60" Height="60" Click="PickImageClick" BorderThickness="1" Padding="0" Tag="2">
                <Image Source="/Images/2.png" Stretch="Uniform"/>
            </Button>
            <Button Width="60" Height="60" Click="PickImageClick" BorderThickness="1" Padding="0" Tag="3">
                <Image Source="/Images/3.png" Stretch="Uniform"/>
            </Button>
            <Button Width="60" Height="60" Click="PickImageClick" BorderThickness="1" Padding="0" Tag="4">
                <Image Source="/Images/4.png" Stretch="Uniform"/>
            </Button>
        </StackPanel>
        <Button Click="LoginClick" Content="Войти"/>
        <Button Click="OpenRegWindowClick" Content="Нет аккаунта"/>
        <Button Click="OpenPhoneValidationClick" Content="Валидация телефона"/>
    </StackPanel>
</Window>
